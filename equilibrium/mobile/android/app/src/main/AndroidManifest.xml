<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for submitting solved blocks -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to start MiningService as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- POST_NOTIFICATIONS for the persistent miner notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- WorkManager constraint: only mine when charging + on unmetered network -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.EquilibriumMiner">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            MiningService — long-running foreground service.
            type="dataSync" is the least-restrictive type allowed for CPU work;
            switch to "specialUse" + declaration if the Play Store policy changes.
        -->
        <service
            android:name=".MiningService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            MiningWorker — used by WorkManager for battery-aware scheduling.
            Constraints: setRequiresCharging(true) + setRequiredNetworkType(UNMETERED)
            are enforced at runtime in MiningWorker.kt.
        -->
        <provider
            android:name="androidx.work.impl.WorkManagerInitializer"
            android:authorities="${applicationId}.workmanager-init"
            android:exported="false"
            tools:node="remove"
            xmlns:tools="http://schemas.android.com/tools" />

    </application>

</manifest>
