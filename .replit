modules = ["nodejs-20", "rust-stable", "python-3.11", "swift-5.8", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

# ── Project (run button) ──────────────────────────────────────────────────────
# Starts services in strict order: Postgres must be ready before the API Server
# connects, and the API Server must be ready before the Explorer starts.
[[workflows.workflow]]
name = "Project"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Postgres"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Explorer"

# ── Postgres ──────────────────────────────────────────────────────────────────
# Idempotent bootstrap: creates role, pushes Drizzle schema, grants privileges,
# then starts postgres in the foreground on port 5432.
# Also runs `pnpm install --frozen-lockfile` on cold boot if node_modules is
# absent so the schema push never fails after a fresh clone or container reset.
[[workflows.workflow]]
name = "Postgres"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-postgres.sh"
waitForPort = 5432

# ── API Server ────────────────────────────────────────────────────────────────
# TypeScript Express node: in-memory chain + Postgres persistence, auto-miner,
# Stratum pool, WebSocket push, Prometheus metrics. Restores persisted chain
# from DB on every start instead of resetting to genesis.
# variational-ai-cli binary is co-located in this directory for the TypeScript
# bridge (artifacts/api-server/src/variational-ai/bridge.ts).
[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DATABASE_URL=postgresql://runner@127.0.0.1:5432/equilibrium PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

# ── Explorer ──────────────────────────────────────────────────────────────────
# React + Vite block explorer and self-custody browser wallet.
[[workflows.workflow]]
name = "Explorer"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/explorer run dev"
waitForPort = 5000

# ── variational-ai: determinism harness ───────────────────────────────────────
# Trains logistic + MLP + NTK on synthetic MNIST, hashes all intermediate
# vectors with SHA-256, and prints the hashes. Run on two architectures and
# diff the output to confirm cross-arch determinism.
[[workflows.workflow]]
name = "VAI Harness"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd variational-ai && cargo run --release --bin variational-ai-harness"

# ── variational-ai: benchmark suite ───────────────────────────────────────────
# Runs all three solver benchmarks (logistic / MLP / NTK) on synthetic MNIST
# and prints accuracy, residual, and wall-clock time for each.
[[workflows.workflow]]
name = "VAI Benchmarks"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd variational-ai && cargo run --release --bin variational-ai"

# ── Agent / environment ───────────────────────────────────────────────────────
[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
REQUIRE_TX_SIGNATURES = "true"
